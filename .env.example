# Whop (from https://whop.com/dashboard/developer/)
NEXT_PUBLIC_WHOP_APP_ID=
WHOP_API_KEY=
WHOP_CLIENT_SECRET=  # Required for OAuth token exchange (extension login)
WHOP_WEBHOOK_SECRET=

# Supabase (from https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=  # required for extension auth (upsert users)

# ShotStack (from https://shotstack.io/dashboard)
SHOTSTACK_STAGING_API_KEY=  # Sandbox/staging (watermarked)
SHOTSTACK_API_KEY=          # Production
SHOTSTACK_TEST_SECRET=      # Secret for POST /api/shotstack/test-render (backend test)
SHOTSTACK_TEST_USER_ID=     # Optional: UUID of user to attribute test renders to

# Upload-Post (from https://upload-post.com)
UPLOAD_POST_API_KEY=        # Main key for cloud posting & managed accounts

# App
NEXT_PUBLIC_APP_ORIGIN=     # e.g. https://extensiblecontent.com (for JWT redirect_url)
CRON_SECRET=                # For Vercel cron (upload-post JWT refresh); set in Vercel dashboard
