{
  "merge": [
    { "find": "QUOTE", "replace": "The only way to do great work is to love what you do." },
    { "find": "AUTHOR", "replace": "— Steve Jobs" },
    { "find": "BG_COLOR", "replace": "#1a1a2e" },
    { "find": "ACCENT_COLOR", "replace": "#e94560" },
    { "find": "TEXT_COLOR", "replace": "#ffffff" },
    { "find": "quote", "replace": "The only way to do great work is to love what you do." },
    { "find": "author", "replace": "— Steve Jobs" },
    { "find": "bgColor", "replace": "#1a1a2e" },
    { "find": "accentColor", "replace": "#e94560" },
    { "find": "textColor", "replace": "#ffffff" },
    { "find": "__CFS_TEMPLATE_ID", "replace": "quote-card" },
    { "find": "__CFS_TEMPLATE_NAME", "replace": "Quote Card" },
    { "find": "__CFS_DESCRIPTION", "replace": "Elegant quote card with accent bar, quote text, and author attribution. Square format for Instagram or social sharing." },
    { "find": "__CFS_OUTPUT_TYPE", "replace": "image" },
    { "find": "__CFS_PRESET_ID", "replace": "instagram_square" },
    { "find": "__CFS_INPUT_SCHEMA", "replace": "[{\"id\":\"quote\",\"label\":\"Quote\",\"type\":\"text\",\"default\":\"The only way to do great work is to love what you do.\",\"mergeField\":\"QUOTE\"},{\"id\":\"author\",\"label\":\"Author\",\"type\":\"text\",\"default\":\"— Steve Jobs\",\"mergeField\":\"AUTHOR\"},{\"id\":\"bgColor\",\"label\":\"Background Color\",\"type\":\"color\",\"default\":\"#1a1a2e\",\"mergeField\":\"BG_COLOR\"},{\"id\":\"accentColor\",\"label\":\"Accent Color\",\"type\":\"color\",\"default\":\"#e94560\",\"mergeField\":\"ACCENT_COLOR\"},{\"id\":\"textColor\",\"label\":\"Text Color\",\"type\":\"color\",\"default\":\"#ffffff\",\"mergeField\":\"TEXT_COLOR\"}]" }
  ],
  "output": {
    "aspectRatio": "1:1",
    "format": "png",
    "fps": 25,
    "resolution": "hd",
    "size": { "width": 1080, "height": 1080 }
  },
  "timeline": {
    "background": "{{ BG_COLOR }}",
    "tracks": [
      {
        "clips": [{
          "alias": "QUOTE_TEXT",
          "asset": {
            "type": "rich-text",
            "text": "{{ QUOTE }}",
            "font": { "family": "Georgia", "size": 44, "color": "{{ TEXT_COLOR }}", "weight": 400, "style": "italic" },
            "align": { "horizontal": "center" }
          },
          "start": 0, "length": 7,
          "width": 880, "height": 400,
          "position": "center",
          "offset": { "x": 0, "y": 0.02 }
        }]
      },
      {
        "clips": [{
          "alias": "AUTHOR_TEXT",
          "asset": {
            "type": "rich-text",
            "text": "{{ AUTHOR }}",
            "font": { "family": "Arial", "size": 28, "color": "{{ TEXT_COLOR }}", "weight": 600 },
            "align": { "horizontal": "center" }
          },
          "start": 0, "length": 7,
          "width": 880, "height": 60,
          "position": "center",
          "offset": { "x": 0, "y": -0.25 }
        }]
      },
      {
        "clips": [{
          "asset": {
            "type": "shape",
            "shape": "rectangle",
            "fill": { "color": "{{ ACCENT_COLOR }}" },
            "rectangle": { "width": 80, "height": 6 }
          },
          "start": 0, "length": 7,
          "fit": "none",
          "position": "center",
          "offset": { "x": 0, "y": 0.28 }
        }]
      },
      {
        "clips": [{
          "asset": {
            "type": "shape",
            "shape": "rectangle",
            "fill": { "color": "{{ BG_COLOR }}" },
            "rectangle": { "width": 1080, "height": 1080 }
          },
          "start": 0, "length": 7,
          "fit": "none",
          "position": "center"
        }]
      }
    ]
  }
}
